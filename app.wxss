/* Global styles */
page {
  --primary: #2864AC;
  --primary-light: #E8F1FA;
  --text-primary: #333;
  --text-secondary: #666;
  --text-tertiary: #999;
  --border: #E5E5E5;
  --bg: #F5F5F5;
  --card: #FFFFFF;
  --danger: #E53935;
  --success: #43A047;
  --warning: #FB8C00;

  background-color: var(--bg);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

.container {
  padding: 24rpx;
}

/* Card */
.card {
  background: var(--card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* Buttons */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
}

.btn-primary[disabled] {
  background: #B5C8D8;
  color: #fff;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 1rpx solid var(--primary);
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
}

/* Typography */
.title-lg { font-size: 40rpx; font-weight: 600; }
.title { font-size: 32rpx; font-weight: 600; }
.subtitle { font-size: 28rpx; color: var(--text-secondary); }
.hint { font-size: 24rpx; color: var(--text-tertiary); }
.danger { color: var(--danger); }
.success { color: var(--success); }
.warning { color: var(--warning); }

/* Form inputs */
.input {
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  background: #fff;
}

/* Tag */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}

.tag-critical { background: #FFEBEE; color: #C62828; }
.tag-high { background: #FFF3E0; color: #E65100; }
.tag-medium { background: #FFF8E1; color: #F57F17; }
.tag-info { background: var(--primary-light); color: var(--primary); }

/* Flex helpers */
.flex { display: flex; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }

/* Spacing */
.mt-8 { margin-top: 16rpx; }
.mt-16 { margin-top: 32rpx; }
.mt-24 { margin-top: 48rpx; }
.mb-8 { margin-bottom: 16rpx; }
.mb-16 { margin-bottom: 32rpx; }
.mb-24 { margin-bottom: 48rpx; }

/* Font scale variants (set on page root) */
.font-scale-large { font-size: 32rpx; }
.font-scale-large .title { font-size: 36rpx; }
.font-scale-large .title-lg { font-size: 44rpx; }
.font-scale-large .subtitle { font-size: 30rpx; }
.font-scale-large .hint { font-size: 26rpx; }

.font-scale-extra-large { font-size: 36rpx; }
.font-scale-extra-large .title { font-size: 40rpx; }
.font-scale-extra-large .title-lg { font-size: 48rpx; }
.font-scale-extra-large .subtitle { font-size: 34rpx; }
.font-scale-extra-large .hint { font-size: 28rpx; }
