/* 材料整理页样式 */

/* 资料整理提示卡片 */
.material-tip {
  background: #F7FBF9;
  border-color: #CFE8DA;
}

.tip-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--success);
  margin-bottom: 8rpx;
}

.tip-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 时间线 */
.timeline {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  margin-bottom: 32rpx;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-left {
  width: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.timeline-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  background: var(--border);
  margin-top: 8rpx;
  min-height: 40rpx;
}

.timeline-content {
  flex: 1;
  padding-left: 24rpx;
  padding-bottom: 8rpx;
}

.timeline-title {
  display: flex;
  align-items: center;
}

.step-badge {
  background: var(--primary);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.step-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.timeline-desc {
  line-height: 1.6;
  white-space: pre-wrap;
}

.call-btn {
  display: inline-block;
  background: var(--success);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.timeline-detail-box {
  background: #F9F9F9;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  white-space: pre-wrap;
}

.material-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
  align-items: flex-start;
}

.material-item:first-child {
  padding-top: 0;
}

.material-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.material-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--primary-light);
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.material-info {
  flex: 1;
}

.material-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.material-intro {
  line-height: 1.5;
}

.doc-card {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.doc-card:last-of-type {
  border-bottom: 0;
}

.doc-head {
  display: flex;
  align-items: flex-start;
}

.doc-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: var(--primary-light);
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.doc-main {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.doc-title {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.doc-desc {
  margin-top: 6rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.45;
}

.doc-price {
  margin-left: 16rpx;
  color: #D97904;
  background: #FFF7E8;
  border-radius: 8rpx;
  padding: 6rpx 12rpx;
  font-size: 24rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.doc-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.doc-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  padding: 0;
  margin: 0;
}

.doc-btn::after {
  border: 0;
}

.doc-btn.ghost {
  color: var(--primary);
  background: #FFFFFF;
  border: 1rpx solid #C6D7EE;
}

.doc-btn.primary {
  color: #FFFFFF;
  background: var(--primary);
}

.doc-note {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  color: var(--text-tertiary);
  background: #F7F9FC;
  font-size: 23rpx;
  line-height: 1.5;
}
