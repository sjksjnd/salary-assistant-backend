<view class="page {{fontScaleClass}}">
  <view class="container">
    <view class="home-top">
      <view class="brand-block">
        <text class="brand-name">薪工记</text>
        <text class="brand-desc">工时、工资、合同核对工具</text>
      </view>
      <view
        class="top-action"
        data-path="/pages/workhours/workhours"
        data-tab="{{true}}"
        bindtap="onTapEntry"
      >
        {{dashboard.actionText}}
      </view>
    </view>

    <view
      class="status-panel"
      data-path="/pages/workhours/workhours"
      data-tab="{{true}}"
      bindtap="onTapEntry"
      hover-class="menu-hover"
      hover-stay-time="100"
    >
      <view class="status-main">
        <view class="status-dot {{dashboard.todayLogged ? 'done' : ''}}"></view>
        <view class="status-copy">
          <text class="status-title">{{dashboard.status}}</text>
          <text class="status-meta">本月已记 {{dashboard.monthDays}} 天 · {{dashboard.monthHours}} 小时</text>
        </view>
      </view>
      <text class="status-arrow">›</text>
    </view>

    <view class="menu-section" wx:for="{{menuGroups}}" wx:key="title">
      <text class="menu-section-title">{{item.title}}</text>
      <view class="menu-list">
        <view
          class="menu-row"
          wx:for="{{item.items}}"
          wx:for-item="menu"
          wx:key="key"
          data-path="{{menu.path}}"
          data-tab="{{menu.isTab}}"
          bindtap="onTapEntry"
          hover-class="menu-hover"
          hover-stay-time="100"
        >
          <view class="menu-icon">{{menu.icon}}</view>
          <view class="menu-copy">
            <text class="menu-title">{{menu.title}}</text>
            <text class="menu-desc">{{menu.desc}}</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="boundary-strip">
      <text>本工具用于记录、测算和常见规则自查，结果仅供核对参考。</text>
    </view>
  </view>
</view>
