<view class="page {{fontScaleClass}}">
  <view class="container">
    <view class="home-top">
      <view class="brand-block">
        <text class="brand-name">薪工记</text>
        <text class="brand-desc">工时、工资、合同核对工具</text>
      </view>
      <view
        class="top-action"
        data-path="/pages/workhours/workhours"
        data-tab="{{true}}"
        bindtap="onTapEntry"
      >
        {{dashboard.actionText}}
      </view>
    </view>

    <view
      class="status-panel"
      data-path="/pages/workhours/workhours"
      data-tab="{{true}}"
      bindtap="onTapEntry"
      hover-class="menu-hover"
      hover-stay-time="100"
    >
      <view class="status-main">
        <view class="status-dot {{dashboard.todayLogged ? 'done' : ''}}"></view>
        <view class="status-copy">
          <text class="status-title">{{dashboard.status}}</text>
          <text class="status-meta">本月已记 {{dashboard.monthDays}} 天 · {{dashboard.monthHours}} 小时</text>
        </view>
      </view>
      <text class="status-arrow">›</text>
    </view>

    <view class="grid-section">
      <view class="section-head">
        <text class="section-title">常用功能</text>
      </view>
      <view class="card-grid">
        <view
          class="grid-card {{item.tone}}"
          wx:for="{{primaryCards}}"
          wx:key="key"
          data-path="{{item.path}}"
          data-tab="{{item.isTab}}"
          bindtap="onTapEntry"
          hover-class="card-hover"
          hover-stay-time="100"
        >
          <view class="grid-icon">{{item.icon}}</view>
          <text class="grid-title">{{item.title}}</text>
          <text class="grid-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="secondary-section">
      <text class="section-title">更多工具</text>
      <view class="secondary-list">
        <view
          class="secondary-row"
          wx:for="{{secondaryTools}}"
          wx:key="key"
          data-path="{{item.path}}"
          data-tab="{{item.isTab}}"
          bindtap="onTapEntry"
          hover-class="menu-hover"
          hover-stay-time="100"
        >
          <view class="secondary-copy">
            <text class="secondary-title">{{item.title}}</text>
            <text class="secondary-desc">{{item.desc}}</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="boundary-strip">
      <text>本工具用于记录、测算和常见规则自查，结果仅供核对参考。</text>
    </view>
  </view>
</view>
