.page {
  min-height: 100vh;
  background: var(--bg);
  padding-top: 28rpx;
  padding-bottom: 40rpx;
}

.home-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 4rpx 24rpx;
}

.brand-block {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.brand-name {
  color: var(--text-primary);
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.brand-desc {
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 25rpx;
  line-height: 1.4;
}

.top-action {
  flex-shrink: 0;
  min-width: 104rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: var(--primary);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.status-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 116rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 1rpx solid #D9E5F4;
  box-shadow: 0 6rpx 20rpx rgba(23, 32, 51, 0.04);
}

.status-main {
  display: flex;
  align-items: center;
  min-width: 0;
}

.status-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #D97904;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.status-dot.done {
  background: #23875D;
}

.status-copy {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.status-title {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.status-meta {
  margin-top: 6rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
  line-height: 1.4;
}

.status-arrow,
.menu-arrow {
  color: #A4AEC0;
  font-size: 42rpx;
  line-height: 1;
  margin-left: 16rpx;
}

.menu-section {
  margin-bottom: 28rpx;
}

.menu-section-title {
  display: block;
  margin: 0 4rpx 12rpx;
  color: var(--text-secondary);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.4;
}

.menu-list {
  overflow: hidden;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  box-shadow: 0 6rpx 20rpx rgba(23, 32, 51, 0.04);
}

.menu-row {
  display: flex;
  align-items: center;
  min-height: 126rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #EEF2F6;
  box-sizing: border-box;
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 14rpx;
  background: #EEF5FF;
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 800;
}

.menu-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  margin-left: 22rpx;
}

.menu-title {
  color: var(--text-primary);
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
}

.menu-desc {
  margin-top: 6rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
  line-height: 1.45;
}

.menu-hover {
  background: #F6F9FD;
}

.boundary-strip {
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
  background: #F1F6F3;
  color: #587163;
  font-size: 24rpx;
  line-height: 1.55;
}
