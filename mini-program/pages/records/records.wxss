.records-page {
  min-height: 100vh;
  box-sizing: border-box;
}

.filter-bar {
  display: flex;
  padding: 8rpx;
  margin-bottom: 24rpx;
  background: #fff;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
}

.filter-item {
  flex: 1;
  padding: 18rpx 8rpx;
  text-align: center;
  color: var(--text-secondary);
  font-size: 28rpx;
  border-radius: 12rpx;
}

.filter-item.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}

.summary-card {
  margin-bottom: 20rpx;
}

.loading-card {
  min-height: 180rpx;
}

.empty-card {
  padding: 80rpx 32rpx;
  text-align: center;
  background: #fff;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-desc {
  display: block;
  margin-top: 16rpx;
  color: var(--text-tertiary);
  font-size: 26rpx;
  line-height: 1.6;
}

.record-card {
  margin-bottom: 20rpx;
}

.card-hover {
  opacity: 0.86;
  transform: scale(0.98);
}

.record-type {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.type-contract {
  background: #F3E8FF;
  color: #7B1FA2;
}

.type-compensation {
  background: #E8F1FA;
  color: var(--primary);
}

.type-default {
  background: #F5F5F5;
  color: var(--text-secondary);
}

.record-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.record-summary {
  display: inline-flex;
  color: var(--text-secondary);
  font-size: 28rpx;
  line-height: 1.6;
}

.record-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.record-open {
  flex-shrink: 0;
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 600;
}

.load-more {
  padding: 24rpx 0 48rpx;
  text-align: center;
}

.modal-mask {
  position: fixed;
  z-index: 99;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.45);
}

.modal-content {
  width: 100%;
  max-height: 82vh;
  padding: 32rpx;
  border-radius: 24rpx 24rpx 0 0;
  background: #fff;
  box-sizing: border-box;
  overflow-y: auto;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 44rpx;
}

.detail-loading {
  margin-top: 24rpx;
  padding: 36rpx 0;
  text-align: center;
}

.detail-report-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 14rpx;
  background: #F5F8FC;
  border: 1rpx solid #DCE8F5;
}

.report-label {
  display: block;
  color: var(--text-tertiary);
  font-size: 24rpx;
}

.report-title-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.overview-num {
  color: var(--primary);
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1;
}

.overview-label {
  color: var(--text-secondary);
  font-size: 26rpx;
}

.source-pill {
  flex-shrink: 0;
  max-width: 260rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #EAF8F0;
  color: #15935B;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
  text-align: center;
}

.issue-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.issue-card {
  padding: 22rpx;
  border: 1rpx solid #E5EAF0;
  border-radius: 14rpx;
  background: #FFFFFF;
}

.issue-head {
  align-items: flex-start;
  gap: 20rpx;
}

.issue-title {
  flex: 1;
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.issue-level {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.level-critical,
.level-high {
  color: #A74400;
  background: #FFF0DA;
}

.level-medium {
  color: #2864AC;
  background: #E8F1FA;
}

.level-low {
  color: #2E7D32;
  background: #E8F5E9;
}

.issue-type {
  display: block;
  color: var(--text-tertiary);
  font-size: 24rpx;
}

.issue-suggestion {
  display: block;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.55;
}

.issue-law {
  display: block;
  color: var(--text-tertiary);
  font-size: 24rpx;
  line-height: 1.5;
}

.empty-detail {
  padding: 28rpx 24rpx;
  border-radius: 14rpx;
  background: #F7F9FC;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}

.article-list {
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.detail-section-title {
  display: block;
  margin-bottom: 12rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 700;
}

.article-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.article-item:last-child {
  border-bottom: none;
}

.article-title {
  display: block;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.45;
}

.article-source {
  display: block;
  margin-top: 6rpx;
  color: var(--text-tertiary);
  font-size: 22rpx;
}

.article-link-btn {
  margin: 14rpx 0 0;
  padding: 0 18rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 10rpx;
  background: #F0F5FB;
  color: var(--primary);
  font-size: 24rpx;
}

.article-link-btn::after {
  border: none;
}

.original-box {
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  background: #FAFAFA;
  border: 1rpx solid #ECEFF3;
}

.original-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.original-toggle {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 700;
}

.original-text {
  display: block;
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.amount-value {
  color: var(--warning);
  font-size: 30rpx;
  font-weight: 700;
}

.modal-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.action-btn {
  flex: 1 1 30%;
  min-width: 180rpx;
  margin: 0;
}
