/* 历史记录入口 */
.history-entry {
  padding: 24rpx 32rpx;
}

.history-arrow {
  color: #999;
  font-size: 36rpx;
  line-height: 1;
}

.intro-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F0F6FF 100%);
  border-color: #D6E5F7;
}

/* 文本输入区 */
.textarea {
  width: 100%;
  height: 360rpx;
  min-height: 360rpx;
  max-height: 360rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #E5E5E5;
  border-radius: 16rpx;
  font-size: 30rpx;
  background: #fff;
  box-sizing: border-box;
  line-height: 1.6;
}

/* 操作栏 */
.action-bar {
  padding: 0 8rpx;
}

.action-gap {
  width: 24rpx;
}

/* 自查按钮 */
.analyze-btn {
  width: 100%;
}

.secondary-action {
  width: 100%;
}

/* loading */
.loading-card {
  padding: 36rpx 32rpx;
}

.loading-head {
  display: flex;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #E5E5E5;
  border-top-color: #2864AC;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  flex-shrink: 0;
}

.loading-copy {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.analyze-progress {
  width: 100%;
  height: 14rpx;
  background: #E8EEF7;
  border-radius: 999rpx;
  overflow: hidden;
}

.analyze-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2864AC 0%, #35A06C 100%);
  border-radius: 999rpx;
  transition: width 0.35s ease;
}

.analyze-steps {
  display: flex;
  flex-direction: column;
}

.analyze-step {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  color: #9CA3AF;
}

.analyze-step.active {
  color: #2864AC;
}

.step-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 1rpx solid currentColor;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 摘要卡片 */
.summary-card {
  padding: 32rpx;
  scroll-margin-top: 24rpx;
}

.complete-badge {
  display: inline-flex;
  align-items: center;
  color: #15935B;
  background: #EAF8F0;
  border: 1rpx solid #BDE7CE;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.summary-text {
  font-size: 32rpx;
}

.summary-total {
  color: #2864AC;
  font-size: 40rpx;
  font-weight: 700;
}

.summary-tags {
  display: flex;
  flex-wrap: wrap;
}

.summary-tags .tag {
  margin-right: 16rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  padding: 8rpx 20rpx;
}

/* 问题项 */
.issue-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E5E5E5;
}

.issue-item:last-child {
  border-bottom: none;
}

.issue-type {
  font-size: 30rpx;
  font-weight: 600;
}

.issue-law {
  display: block;
  font-size: 28rpx;
  color: #2864AC;
  font-weight: 600;
}

.issue-law-text {
  display: block;
  line-height: 1.6;
}

.issue-suggestion {
  padding: 20rpx;
  background: #F6F8FB;
  border-radius: 16rpx;
}

/* 法条 */
.law-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #E5E5E5;
}

.law-item:last-child {
  border-bottom: none;
}

.law-source {
  display: block;
  font-size: 28rpx;
  color: #2864AC;
  font-weight: 600;
}

.law-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.law-title {
  display: block;
}

.law-text {
  display: block;
  line-height: 1.6;
}

.law-link-btn {
  margin-top: 16rpx;
  margin-left: 0;
  padding: 0 20rpx;
  height: 56rpx;
  line-height: 54rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  border: 1rpx solid #2864AC;
  background: #FFFFFF;
  color: #2864AC;
  font-size: 24rpx;
}

.law-link-btn::after {
  border: none;
}

/* 协商卡片 */
.negotiate-card {
  background: #F7FBF9;
  border-color: #CFE8DA;
}
