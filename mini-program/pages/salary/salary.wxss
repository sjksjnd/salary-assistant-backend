/* 工资核对页样式 */
.salary-page {
  padding-bottom: 32rpx;
}

/* 月份切换器 */
.month-switcher {
  padding: 24rpx 32rpx;
}

.month-arrow {
  font-size: 36rpx;
  color: var(--primary);
  padding: 8rpx 24rpx;
}

/* 工资核对 */
.salary-check-card {
  background: #FFFFFF;
  border-color: #D7E4F4;
}

.check-title {
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
}

.status-pill {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.status-pill.neutral {
  color: #6B7280;
  background: #F3F4F6;
}

.status-pill.warning {
  color: #A74400;
  background: #FFF0DA;
}

.status-pill.success {
  color: #15935B;
  background: #EAF8F0;
}

.salary-main {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.salary-main-item {
  min-height: 142rpx;
  padding: 22rpx;
  border: 1rpx solid #E5EAF0;
  border-radius: 14rpx;
  background: #F8FAFD;
  box-sizing: border-box;
}

.salary-label {
  display: block;
  color: var(--text-tertiary);
  font-size: 24rpx;
}

.salary-value {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.salary-value.primary {
  color: var(--primary);
}

.salary-value.success {
  color: #15935B;
}

.gap-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  border-radius: 14rpx;
}

.gap-card.warning {
  background: #FFF6E6;
}

.gap-card.success {
  background: #EAF8F0;
}

.gap-label {
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 700;
}

.gap-value {
  color: #D97706;
  font-size: 40rpx;
  font-weight: 800;
}

.gap-card.success .gap-value {
  color: #15935B;
}

.insight-card {
  display: block;
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  border: 1rpx solid transparent;
}

.insight-card.neutral {
  background: #F5F8FC;
  border-color: #DCE8F5;
}

.insight-card.warning {
  background: #FFF6E6;
  border-color: #FFE0A8;
}

.insight-card.success {
  background: #EAF8F0;
  border-color: #CDEEDB;
}

.insight-title {
  display: block;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.4;
}

.insight-desc {
  display: block;
  color: var(--text-secondary);
  font-size: 25rpx;
  line-height: 1.55;
}

.work-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-top: 1rpx solid var(--border);
  padding-top: 20rpx;
}

.work-metric {
  text-align: center;
}

.metric-num {
  display: block;
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.metric-label {
  display: block;
  margin-top: 8rpx;
  color: var(--text-tertiary);
  font-size: 22rpx;
}

.check-hint {
  color: var(--text-tertiary);
  font-size: 24rpx;
  line-height: 1.55;
  background: #F7F9FC;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.data-warning {
  margin: -8rpx 0 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #FFF8E1;
  color: #A15C00;
  font-size: 24rpx;
  line-height: 1.5;
}

/* 概览卡片 */
.overview-card {
  text-align: center;
}

.overview-row {
  margin-top: 0;
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-amount {
  font-size: 30rpx;
  margin-top: 8rpx;
  font-weight: 600;
}

.remaining-row {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
  text-align: left;
}

.remaining-amount {
  font-size: 40rpx;
  font-weight: 700;
}

/* 操作网格 */
.action-grid {
  display: flex;
  flex-wrap: wrap;
  background: var(--card);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.action-item {
  width: 33.333%;
  padding: 24rpx 12rpx;
  text-align: center;
  box-sizing: border-box;
}

.action-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 16rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0F5FB;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 800;
}

.action-label {
  font-size: 26rpx;
  margin-top: 12rpx;
  color: var(--text-primary);
  font-weight: 600;
}

/* 分类统计列表 */
.stat-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.stat-left {
  width: 180rpx;
  display: flex;
  align-items: center;
}

.stat-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.stat-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.stat-bar-wrap {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  margin: 0 24rpx;
  overflow: hidden;
}

.stat-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.expense-bar {
  background: var(--warning);
}

.deduction-bar {
  background: var(--danger);
}

.stat-right {
  width: 160rpx;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.stat-amount {
  font-size: 28rpx;
  color: var(--text-primary);
}

.stat-percent {
  margin-left: 8rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  overflow-y: auto;
}

.modal-header {
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-tertiary);
  padding: 0 8rpx;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.picker-display {
  color: var(--text-primary);
}

/* 月度账单 */
.bill-content {
  max-height: 88vh;
}

.bill-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-radius: 16rpx;
  background: #F6F8FB;
  border: 1rpx solid #E5E7EB;
}

.bill-remaining {
  font-size: 52rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.bill-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.bill-pill.positive {
  color: #15935B;
  background: #EAF8F0;
}

.bill-pill.negative {
  color: #DC2626;
  background: #FEF2F2;
}

.bill-bar-row {
  padding: 14rpx 0;
}

.bill-bar-head {
  margin-bottom: 10rpx;
}

.bill-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.bill-bar-track {
  width: 100%;
  height: 18rpx;
  background: #EEF2F6;
  border-radius: 999rpx;
  overflow: hidden;
}

.bill-bar-fill {
  height: 100%;
  border-radius: 999rpx;
}

.bill-bar-fill.income {
  background: #2864AC;
}

.bill-bar-fill.actual {
  background: #15935B;
}

.bill-bar-fill.deduction {
  background: #DC2626;
}

.bill-bar-fill.expense {
  background: #F59E0B;
}

.bill-bar-fill.advance {
  background: #6B7280;
}

.bill-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.bill-metric {
  flex: 1 1 calc(50% - 8rpx);
  min-width: 220rpx;
  padding: 20rpx;
  border: 1rpx solid #E5E7EB;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
}

.metric-value {
  font-size: 32rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.metric-value.success {
  color: #15935B;
}

.metric-value.danger {
  color: #D93025;
}

.bill-section {
  padding-top: 12rpx;
  border-top: 1rpx solid #E5E7EB;
}

.bill-mini-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 12rpx 0;
}

.detail-card {
  padding-bottom: 12rpx;
}

.detail-section {
  padding-top: 18rpx;
  border-top: 1rpx solid #EEF2F6;
}

.detail-section:first-of-type {
  border-top: 0;
}

.detail-section-head {
  margin-bottom: 8rpx;
}

.money-record {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F0F3F7;
}

.money-record:last-child {
  border-bottom: 0;
}

.record-main {
  min-width: 0;
  flex: 1;
  padding-right: 16rpx;
}

.record-name {
  display: block;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.record-meta {
  display: block;
  margin-top: 6rpx;
  color: var(--text-tertiary);
  font-size: 23rpx;
  line-height: 1.4;
  word-break: break-all;
}

.record-side {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.record-amount {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 800;
  margin-right: 14rpx;
}

.record-edit,
.record-delete {
  min-width: 88rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #D93025;
  background: #FFF1F0;
  font-size: 23rpx;
}

.record-edit {
  color: #2864AC;
  background: #EEF5FF;
  margin-right: 10rpx;
}

.record-delete::after {
  border: 0;
}

.record-edit::after {
  border: 0;
}

/* 分类选择网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -6rpx;
}

.category-item {
  width: calc(25% - 12rpx);
  margin: 6rpx;
  text-align: center;
  padding: 16rpx 8rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  background: #fff;
}

.category-item.active {
  background: var(--primary-light);
  border-color: var(--primary);
}

.cat-icon {
  font-size: 36rpx;
  display: block;
}

.cat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-state {
  padding: 64rpx 32rpx;
  text-align: center;
}

/* 扣款超出警告条 */
.warning-bar {
  background: #FFF8E1;
  border: 1rpx solid #FFB300;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #F57C00;
  text-align: center;
}

/* 闪烁动画 */
.blink {
  animation: blink 1s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 分享图片样式 */
.share-content {
  max-height: 90vh;
}

.share-image {
  width: 100%;
  border-radius: 16rpx;
}

.share-hint {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-tertiary);
  padding-bottom: 24rpx;
}
