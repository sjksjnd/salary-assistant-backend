/* Global styles */
page {
  --primary: #1F5EAF;
  --primary-light: #EAF3FF;
  --text-primary: #172033;
  --text-secondary: #5B667A;
  --text-tertiary: #8A95A8;
  --border: #E3E9F2;
  --bg: #F6F8FB;
  --card: #FFFFFF;
  --danger: #E53935;
  --success: #23875D;
  --warning: #D97904;

  background-color: var(--bg);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

.container {
  padding: 28rpx 24rpx;
}

/* Card */
.card {
  background: var(--card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 8rpx 28rpx rgba(23, 32, 51, 0.05);
}

/* Buttons */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 16rpx;
  padding: 18rpx 36rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
  line-height: 1.45;
  font-weight: 600;
  box-shadow: 0 8rpx 18rpx rgba(31, 94, 175, 0.18);
}

.btn-primary::after,
.btn-outline::after {
  border: none;
}

.btn-primary[disabled] {
  background: #B5C8D8;
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: var(--primary);
  border: 1rpx solid #B8CAE2;
  border-radius: 16rpx;
  padding: 18rpx 36rpx;
  font-size: 30rpx;
  text-align: center;
  line-height: 1.45;
  font-weight: 600;
}

/* Typography */
.title-lg { font-size: 42rpx; font-weight: 700; color: var(--text-primary); }
.title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); }
.subtitle { font-size: 28rpx; color: var(--text-secondary); }
.hint { font-size: 24rpx; color: var(--text-tertiary); }
.danger { color: var(--danger); }
.success { color: var(--success); }
.warning { color: var(--warning); }

/* Form inputs */
.input {
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  background: #fff;
}

/* Tag */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
  line-height: 1.4;
}

.tag-critical { background: #FFEBEE; color: #C62828; }
.tag-high { background: #FFF3E0; color: #E65100; }
.tag-medium { background: #FFF8E1; color: #F57F17; }
.tag-info { background: var(--primary-light); color: var(--primary); }

/* Flex helpers */
.flex { display: flex; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }

/* Spacing */
.mt-8 { margin-top: 16rpx; }
.mt-16 { margin-top: 32rpx; }
.mt-24 { margin-top: 48rpx; }
.mb-8 { margin-bottom: 16rpx; }
.mb-16 { margin-bottom: 32rpx; }
.mb-24 { margin-bottom: 48rpx; }

