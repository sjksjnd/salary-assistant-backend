<!-- pages/legal/legal.wxml -->
<view class="page {{fontScaleClass}}">
  <view class="container">

    <!-- 搜索框 -->
    <view class="search-section">
      <view class="search-box">
        <text class="search-icon">🔍</text>
        <input class="search-input"
               placeholder="输入问题，如：试用期多久才合法？"
               value="{{question}}"
               bindinput="onQuestionInput"
               bindconfirm="onSearch"
               confirm-type="search" />
        <view wx:if="{{question}}" class="clear-btn" bindtap="clearQuestion">×</view>
      </view>
      <button class="search-btn" bindtap="onSearch" loading="{{searching}}" disabled="{{!question || searching}}">
        搜索
      </button>
    </view>

    <!-- 热门问题 -->
    <view class="section" wx:if="{{!hasSearched}}">
      <view class="section-title">热门问题</view>
      <view class="hot-questions">
        <view class="hot-tag" wx:for="{{hotQuestions}}" wx:key="*this" bindtap="onHotQuestionTap" data-q="{{item}}">
          {{item}}
        </view>
      </view>
    </view>

    <!-- 分类浏览 -->
    <view class="section" wx:if="{{!hasSearched}}">
      <view class="section-title">按分类浏览</view>
      <view class="category-grid">
        <view class="category-item" wx:for="{{categories}}" wx:key="key" bindtap="onCategoryTap" data-cat="{{item.key}}">
          <text class="category-icon">{{categoryIcons[item.key] || '📋'}}</text>
          <text class="category-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 搜索结果 -->
    <view wx:if="{{hasSearched}}">
      <!-- 结果统计 -->
      <view class="result-header" wx:if="{{totalResults > 0}}">
        <text class="result-count">共找到 {{totalResults}} 条相关法律条文</text>
      </view>

      <!-- 无结果提示 -->
      <view class="empty-state" wx:if="{{totalResults === 0}}">
        <text class="empty-icon">🔍</text>
        <text class="empty-title">未找到相关法律条文</text>
        <text class="empty-hint">试试换个关键词，或查看分类浏览</text>
      </view>

      <!-- 结果列表 -->
      <view class="result-list">
        <view class="result-card" wx:for="{{results}}" wx:key="id" bindtap="onArticleTap" data-article="{{item}}">
          <view class="result-header">
            <text class="result-tag">{{item.categoryLabel}}</text>
            <text class="result-title">{{item.title}}</text>
          </view>
          <view class="result-source">{{item.source}}</view>
          
          <!-- 北大法宝来源标识 -->
          <view class="pkulaw-badge" wx:if="{{item.fromPkulaw}}">
            <text class="pkulaw-icon">📚</text>
            <text class="pkulaw-text">数据来源：北大法宝</text>
          </view>
          
          <!-- 快速答案 -->
          <view class="quick-answer" wx:if="{{item.quickAnswer}}">
            <text class="quick-label">快速解答：</text>
            <text class="quick-text">{{item.quickAnswer}}</text>
          </view>

          <!-- 匹配关键词 -->
          <view class="matched-keywords" wx:if="{{item.matchedKeywords && item.matchedKeywords.length > 0}}">
            <text class="kw-label">匹配关键词：</text>
            <text class="kw-tag" wx:for="{{item.matchedKeywords}}" wx:for-item="kw" wx:key="*this">{{kw}}</text>
          </view>

          <view class="result-arrow">›</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 法条详情弹窗 -->
  <view class="modal-mask" wx:if="{{showDetail}}" bindtap="closeDetail">
    <view class="detail-modal" catchtap="">
      <view class="detail-header">
        <text class="detail-title">{{currentArticle.title}}</text>
        <view class="detail-close" bindtap="closeDetail">×</view>
      </view>
      <scroll-view scroll-y class="detail-body">
        <view class="detail-source">{{currentArticle.source}}</view>
        <view class="detail-category">
          <text class="detail-tag">{{currentArticle.categoryLabel}}</text>
          <text class="detail-tag timeliness-valid" wx:if="{{currentArticle.timeliness === '现行有效'}}">✓ {{currentArticle.timeliness}}</text>
          <text class="detail-tag timeliness-warning" wx:elif="{{currentArticle.timeliness && currentArticle.timeliness !== '现行有效'}}">⚠ {{currentArticle.timeliness}}</text>
        </view>

        <view class="detail-meta" wx:if="{{currentArticle.fromPkulaw}}">
          <view class="meta-item" wx:if="{{currentArticle.effectiveness}}">
            <text class="meta-label">效力位阶</text>
            <text class="meta-value">{{currentArticle.effectiveness}}</text>
          </view>
          <view class="meta-item" wx:if="{{currentArticle.issueDepartment}}">
            <text class="meta-label">制定机关</text>
            <text class="meta-value">{{currentArticle.issueDepartment}}</text>
          </view>
          <view class="meta-item" wx:if="{{currentArticle.implementationDate}}">
            <text class="meta-label">施行日期</text>
            <text class="meta-value">{{currentArticle.implementationDate}}</text>
          </view>
          <view class="meta-item" wx:if="{{currentArticle.docNo}}">
            <text class="meta-label">发文字号</text>
            <text class="meta-value">{{currentArticle.docNo}}</text>
          </view>
        </view>

        <view class="detail-section-title">法律条文</view>
        <view class="detail-text">{{currentArticle.originalText}}</view>
        
        <view class="detail-section-title" wx:if="{{currentArticle.keywords && currentArticle.keywords.length > 0}}">关键词</view>
        <view class="detail-keywords" wx:if="{{currentArticle.keywords && currentArticle.keywords.length > 0}}">
          <text class="kw-tag" wx:for="{{currentArticle.keywords}}" wx:for-item="kw" wx:key="*this">{{kw}}</text>
        </view>

        <!-- 查看原文按钮 -->
        <view class="detail-footer" wx:if="{{currentArticle.pkulawUrl || currentArticle.fromPkulaw}}">
          <button class="view-original-btn" bindtap="onViewOriginal" data-url="{{currentArticle.pkulawUrl}}">
            🔗 在北大法宝查看原文
          </button>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
