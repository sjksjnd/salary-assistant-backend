/* pages/legal/legal.wxss */

.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.container {
  padding: 24rpx;
}

/* 搜索区 */
.search-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 48rpx;
  padding: 0 24rpx;
  height: 80rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: #e0e0e0;
  color: #666;
  border-radius: 50%;
  font-size: 28rpx;
}

.search-btn {
  background: var(--primary, #2864AC);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 32rpx;
  margin: 0;
}

.search-btn::after {
  border: none;
}

.search-btn[disabled] {
  background: #9ab8d4;
  color: #fff;
}

/* 区块标题 */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

/* 热门问题 */
.hot-questions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-tag {
  background: #fff;
  color: var(--text-primary, #333);
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  border: 1rpx solid #eee;
}

/* 分类网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.category-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.category-icon {
  font-size: 48rpx;
}

.category-label {
  font-size: 24rpx;
  color: var(--text-primary, #333);
  text-align: center;
}

/* 搜索结果 */
.result-header {
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.result-count {
  font-size: 26rpx;
  color: var(--text-secondary, #666);
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  position: relative;
  padding-right: 60rpx;
}

.result-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  padding: 0;
}

.result-tag {
  background: #E3F2FD;
  color: var(--primary, #2864AC);
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
  flex: 1;
}

.result-source {
  font-size: 24rpx;
  color: var(--text-secondary, #666);
  margin-bottom: 16rpx;
}

.quick-answer {
  background: #FFF8E1;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.quick-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #F57C00;
  margin-right: 8rpx;
}

.quick-text {
  font-size: 26rpx;
  color: var(--text-primary, #333);
  line-height: 1.6;
}

.matched-keywords {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.kw-label {
  font-size: 22rpx;
  color: var(--text-tertiary, #999);
  margin-right: 4rpx;
}

.kw-tag {
  background: #F5F5F5;
  color: var(--text-secondary, #666);
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.result-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  color: var(--text-tertiary, #ccc);
}

/* 北大法宝来源标识 */
.pkulaw-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
  padding: 8rpx 16rpx;
  background: #F0F4FF;
  border-radius: 8rpx;
  align-self: flex-start;
}

.pkulaw-icon {
  font-size: 24rpx;
}

.pkulaw-text {
  font-size: 22rpx;
  color: #5B6FC7;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 30rpx;
  color: var(--text-primary, #333);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary, #666);
}

/* 详情弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-modal {
  width: 90%;
  max-width: 680rpx;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
}

.detail-close {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 40rpx;
  color: var(--text-tertiary, #999);
}

.detail-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.detail-source {
  font-size: 26rpx;
  color: var(--primary, #2864AC);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.detail-category {
  margin-bottom: 24rpx;
}

.detail-tag {
  background: #E3F2FD;
  color: var(--primary, #2864AC);
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.timeliness-valid {
  background: #E8F5E9;
  color: #43A047;
}

.timeliness-warning {
  background: #FFF3E0;
  color: #FB8C00;
}

.detail-meta {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin: 20rpx 0;
}

.meta-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.meta-item:last-child {
  border-bottom: none;
}

.meta-label {
  font-size: 24rpx;
  color: #999;
}

.meta-value {
  font-size: 24rpx;
  color: #333;
  max-width: 400rpx;
  text-align: right;
}

.detail-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
  margin: 24rpx 0 16rpx;
}

.detail-section-title:first-child {
  margin-top: 0;
}

.detail-text {
  font-size: 28rpx;
  color: var(--text-primary, #333);
  line-height: 1.8;
}

.detail-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 查看原文按钮 */
.detail-footer {
  margin-top: 40rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.view-original-btn {
  width: 100%;
  background: var(--primary, #2864AC);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
}

.view-original-btn::after {
  border: none;
}
