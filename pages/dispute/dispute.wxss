/* 争议解决页样式 */

/* 协商优先提示卡片 */
.consult-tip {
  background: #FFF8E1;
  border-color: #FFE082;
}

.tip-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #E65100;
  margin-bottom: 8rpx;
}

.tip-desc {
  font-size: 28rpx;
  color: #6D4C41;
  line-height: 1.6;
}

/* 时间线 */
.timeline {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  margin-bottom: 32rpx;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-left {
  width: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.timeline-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  background: var(--border);
  margin-top: 8rpx;
  min-height: 40rpx;
}

.timeline-content {
  flex: 1;
  padding-left: 24rpx;
  padding-bottom: 8rpx;
}

.timeline-title {
  display: flex;
  align-items: center;
}

.step-badge {
  background: var(--primary);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.step-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.timeline-desc {
  line-height: 1.6;
}

.call-btn {
  display: inline-block;
  background: var(--success);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.timeline-detail-box {
  background: #F9F9F9;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 文书模板 */
.template-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
  align-items: center;
}

.template-item:first-child {
  padding-top: 0;
}

.template-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.template-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.template-intro {
  line-height: 1.5;
}

.template-price {
  color: var(--danger);
  font-size: 28rpx;
  font-weight: 600;
}

.template-actions {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  margin-left: 24rpx;
  min-width: 160rpx;
}

.template-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  text-align: center;
}

/* 法律依据 */
.loading-hint {
  text-align: center;
  padding: 32rpx 0;
}

.article-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.article-item:first-child {
  padding-top: 0;
}

.article-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.article-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.article-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  padding: 24rpx 32rpx 48rpx;
  line-height: 1.6;
}

/* 模板详情弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-tertiary);
  padding: 0 8rpx;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
  max-height: 70vh;
  box-sizing: border-box;
}

.template-price-row {
  display: flex;
  align-items: baseline;
}

.desensitize-hint {
  margin-left: 12rpx;
}

.template-full-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.7;
  white-space: pre-wrap;
  background: #F9F9F9;
  padding: 24rpx;
  border-radius: 12rpx;
}
