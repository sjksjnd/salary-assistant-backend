/* 首页样式 */
.page {
  min-height: 100vh;
  background: var(--bg);
}

/* 顶部内边距 */
.pt-6 {
  padding-top: 48rpx;
}

/* 顶部欢迎语 */
.header {
  text-align: center;
}

/* 2×2 网格布局 */
.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.grid-item {
  width: 340rpx;
  box-sizing: border-box;
  align-items: flex-start;
}

/* 卡片点击反馈 */
.card-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 图标圆角方块 */
.icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-emoji {
  font-size: 28rpx;
  line-height: 1;
}

/* 功能标题 */
.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.feature-sub {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 底部说明 */
.footer {
  text-align: center;
}

.footer .hint {
  line-height: 1.8;
}
