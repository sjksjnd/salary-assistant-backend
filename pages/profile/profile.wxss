/* pages/profile/profile.wxss */

.page {
  min-height: 100vh;
  background: var(--bg);
  padding: 24rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* 字体缩放 - small 自定义（其余继承自 app.wxss） */
.font-scale-small { font-size: 24rpx; }
.font-scale-small .title { font-size: 28rpx; }
.font-scale-small .title-lg { font-size: 36rpx; }
.font-scale-small .subtitle { font-size: 24rpx; }
.font-scale-small .hint { font-size: 20rpx; }

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: var(--card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 60rpx;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.username {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.user-meta {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
}

.arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  transition: transform 0.2s;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.arrow.expanded {
  transform: rotate(90deg);
}

/* 菜单组 */
.menu-group {
  background: var(--card);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.menu-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.menu-cell:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

/* 设置面板 */
.settings-panel {
  padding: 0 32rpx;
  background: #FAFAFA;
  border-top: 1rpx solid var(--border);
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.setting-input {
  width: 200rpx;
  text-align: right;
  font-size: 28rpx;
  padding: 12rpx 16rpx;
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  background: #fff;
  box-sizing: border-box;
}

.option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option-btn {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  border: 1rpx solid var(--border);
  background: #fff;
  color: var(--text-secondary);
}

.option-btn.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.picker-value {
  font-size: 28rpx;
  color: var(--primary);
  padding: 8rpx 20rpx;
  background: var(--primary-light);
  border-radius: 8rpx;
}
