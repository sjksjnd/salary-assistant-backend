/* 工资管理页样式 */

/* 月份切换器 */
.month-switcher {
  padding: 24rpx 32rpx;
}

.month-arrow {
  font-size: 36rpx;
  color: var(--primary);
  padding: 8rpx 24rpx;
}

/* 概览卡片 */
.overview-card {
  text-align: center;
}

.net-salary {
  font-size: 60rpx;
  font-weight: 700;
  color: var(--primary);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

.overview-row {
  margin-top: 32rpx;
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-amount {
  font-size: 30rpx;
  margin-top: 8rpx;
  font-weight: 600;
}

.remaining-row {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
}

.remaining-amount {
  font-size: 40rpx;
  font-weight: 700;
}

/* 操作网格 */
.action-grid {
  display: flex;
  flex-wrap: wrap;
  background: var(--card);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.action-item {
  width: 50%;
  padding: 32rpx 16rpx;
  text-align: center;
  box-sizing: border-box;
}

.action-icon {
  font-size: 56rpx;
}

.action-label {
  font-size: 30rpx;
  margin-top: 12rpx;
  color: var(--text-primary);
}

/* 分类统计列表 */
.stat-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.stat-left {
  width: 180rpx;
  display: flex;
  align-items: center;
}

.stat-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.stat-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.stat-bar-wrap {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  margin: 0 24rpx;
  overflow: hidden;
}

.stat-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.expense-bar {
  background: var(--warning);
}

.deduction-bar {
  background: var(--danger);
}

.stat-right {
  width: 160rpx;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.stat-amount {
  font-size: 28rpx;
  color: var(--text-primary);
}

.stat-percent {
  margin-left: 8rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  overflow-y: auto;
}

.modal-header {
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-tertiary);
  padding: 0 8rpx;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.picker-display {
  color: var(--text-primary);
}

/* 分类选择网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -6rpx;
}

.category-item {
  width: calc(25% - 12rpx);
  margin: 6rpx;
  text-align: center;
  padding: 16rpx 8rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  background: #fff;
}

.category-item.active {
  background: var(--primary-light);
  border-color: var(--primary);
}

.cat-icon {
  font-size: 36rpx;
  display: block;
}

.cat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-state {
  padding: 64rpx 32rpx;
  text-align: center;
}

/* 扣款超出警告条 */
.warning-bar {
  background: #FFF8E1;
  border: 1rpx solid #FFB300;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #F57C00;
  text-align: center;
}

/* 闪烁动画 */
.blink {
  animation: blink 1s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 分享图片样式 */
.share-content {
  max-height: 90vh;
}

.share-image {
  width: 100%;
  border-radius: 16rpx;
}

.share-hint {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-tertiary);
  padding-bottom: 24rpx;
}
