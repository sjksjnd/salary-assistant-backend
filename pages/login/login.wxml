<!-- pages/login/login.wxml -->
<view class="page">
  <view class="logo-section">
    <view class="logo-circle">
      <text class="logo-icon">工</text>
    </view>
    <view class="app-title">工友守护·薪工记</view>
    <view class="welcome-text">记录工时工资，管理自己的劳动凭证</view>
  </view>

  <view class="form-section" wx:if="{{showUserForm}}">
    <view class="form-title">完善个人信息</view>

    <view class="form-row">
      <view class="form-label">头像</view>
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="avatar-preview" mode="aspectFill" />
        <text wx:else class="avatar-placeholder">选择头像</text>
      </button>
    </view>

    <view class="form-row">
      <view class="form-label">昵称</view>
      <input
        type="nickname"
        class="nickname-input"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <button class="login-btn mt-32" bindtap="submitUserForm">确认</button>
  </view>

  <view class="login-section" wx:else>
    <button class="login-btn" bindtap="wechatLogin" disabled="{{!agreed || logging}}">
      {{logging ? '登录中...' : '微信一键登录'}}
    </button>

    <view class="agreement-row">
      <view class="checkbox {{agreed ? 'checked' : ''}}" bindtap="toggleAgreement">
        <text wx:if="{{agreed}}" class="check-icon">✓</text>
      </view>
      <view class="agreement-text">
        我已阅读并同意
        <text class="agreement-link" catchtap="showAgreement">《用户协议》</text>
        和
        <text class="agreement-link" catchtap="showPrivacy">《隐私政策》</text>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showAgreement || showPrivacy}}" bindtap="closeAgreementModal">
    <view class="modal" catchtap="stopPropagation">
      <view class="modal-title">{{showAgreement ? '用户协议' : '隐私政策'}}</view>
      <scroll-view scroll-y class="modal-content">
        <block wx:if="{{showAgreement}}">
          <view class="modal-section">一、服务说明</view>
          <view class="modal-paragraph">本应用提供工时记录、工资核对、合同条款自查和常见规则信息整理等服务。</view>
          <view class="modal-section">二、用户义务</view>
          <view class="modal-paragraph">用户应合法使用本应用，并保证自行填写的信息真实、准确、合法。</view>
          <view class="modal-section">三、服务边界</view>
          <view class="modal-paragraph">本应用内容仅供记录核对参考，不替代专业机构意见，也不代办任何争议处理事项。需要人工核实时，可联系当地人社部门、12333 热线或工会等公开渠道。</view>
        </block>
        <block wx:else>
          <view class="modal-section">一、信息收集</view>
          <view class="modal-paragraph">本应用仅在必要范围内处理微信登录信息、用户主动填写的工时工资记录和偏好设置。</view>
          <view class="modal-section">二、信息使用</view>
          <view class="modal-paragraph">相关信息用于提供应用功能、同步云端数据和改善使用体验，不会用于无关用途。</view>
          <view class="modal-section">三、数据安全</view>
          <view class="modal-paragraph">我们会采取合理措施保护数据安全。你可以在个人中心清除本地数据或退出登录。</view>
        </block>
      </scroll-view>
      <view class="modal-close" bindtap="closeAgreementModal">我知道了</view>
    </view>
  </view>
</view>
