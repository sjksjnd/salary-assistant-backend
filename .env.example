# ===== Server =====
NODE_ENV=development
PORT=3000

# ===== Database (MySQL) =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=salary_assistant
DB_USER=root
DB_PASSWORD=your_password_here

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== JWT =====
JWT_SECRET=your_jwt_secret_at_least_32_bytes_long
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d

# ===== WeChat Mini Program =====
WX_APPID=your_wechat_appid
WX_SECRET=your_wechat_secret
# Optional: trust a cloud proxy CA for WeChat login only.
# WECHAT_CA_CERT_PATH=/path/to/ca.pem
# Emergency only: disable TLS verification for WeChat login only.
# Accepted false values: false, 0, no, off
# WECHAT_TLS_REJECT_UNAUTHORIZED=false

# ===== Admin Access =====
# Protects global config write/list/delete APIs. Use comma-separated values.
# ADMIN_USER_IDS=1
# ADMIN_OPENIDS=openid1,openid2

# ===== Node.js TLS/SSL =====
# Add custom CA certificates for outbound HTTPS requests (cloud environment)
# NODE_EXTRA_CA_CERTS=/path/to/ca-bundle.crt

# ===== Reverse Proxy =====
# Default trusts local/private proxies only. Use 1 if your platform requires hop count.
# TRUST_PROXY=1

# ===== OSS / COS =====
OSS_BUCKET=your_bucket_name
OSS_REGION=ap-guangzhou
OSS_ACCESS_KEY=your_access_key
OSS_SECRET_KEY=your_secret_key

# ===== OCR (Tencent Cloud) =====
OCR_SECRET_ID=your_ocr_secret_id
OCR_SECRET_KEY=your_ocr_secret_key

# ===== Content Safety (WeChat msgSecCheck) =====
MSG_SEC_CHECK_TOKEN=your_token

# ===== Rate Limiting =====
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_LOGIN=5
RATE_LIMIT_FORUM=3
RATE_LIMIT_CONTRACT=5
RATE_LIMIT_CALC=10

# ===== PKULaw MCP (北大法宝) =====
PKULAW_MCP_URL=https://apim-gateway.pkulaw.com/mcp-law-search-service
PKULAW_MCP_TOKEN=
PKULAW_MCP_TIMEOUT=15000
PKULAW_TOOL_SEARCH=search_article
PKULAW_TOOL_GET=get_article

# ===== PKULaw Protection (防刷量) =====
PKULAW_CACHE_TTL=3600
PKULAW_USER_DAILY_LIMIT=20
PKULAW_GLOBAL_DAILY_LIMIT=500
